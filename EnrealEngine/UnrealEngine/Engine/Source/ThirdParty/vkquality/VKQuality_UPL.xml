<?xml version="1.0" encoding="utf-8"?>
<!--VKQuality plugin additions-->
<root xmlns:android="http://schemas.android.com/apk/res/android">
  <!-- init section is always evaluated once per architecture -->
  <init>
    <log text="VKQuality init"/>
    <setBool result="bSupported" value="false"/>
    <isArch arch="x86_64">
      <setBool result="bSupported" value="true"/>
    </isArch>
    <isArch arch="arm64-v8a">
      <setBool result="bSupported" value="true"/>
    </isArch>
    <if condition="bSupported">
      <false>
        <log text="Unsupported architecture: $S(Architecture)"/>
      </false>
    </if>
  </init>

  <!-- optional files or directories to copy to Intermediate/Android/APK -->
  <resourceCopies>
    <if condition="bSupported">
      <true>
        <copyFile src="$S(AbsPluginDir)/libs/$S(Architecture)/libvkquality.so"
					dst="$S(BuildDir)/libs/$S(Architecture)/libvkquality.so" />
        <log text="Copying libvkquality.so"/>
		<copyFile src="$S(AbsPluginDir)/vkq_library/vkquality/src/main/assets/vkqualitydata.vkq"
					dst="$S(BuildDir)/assets/vkqualitydata.vkq" />
		<log text="Copying vkqualitydata.vkq"/>
	  </true>
    </if>
  </resourceCopies>
</root>
